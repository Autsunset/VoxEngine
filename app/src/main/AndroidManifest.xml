<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <application
        android:name=".VoxEngineApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MiMoTTS">

        <!-- 主界面 -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.MiMoTTS">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- TTS 引擎配置入口 -->
            <intent-filter>
                <action android:name="android.speech.tts.engine.CONFIGURE_ENGINE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- TTS 引擎检查语音数据 -->
        <activity
            android:name=".tts.CheckVoiceData"
            android:exported="true">
            <intent-filter>
                <action android:name="android.speech.tts.engine.CHECK_TTS_DATA" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- TTS 引擎获取示例文本 -->
        <activity
            android:name=".tts.GetSampleText"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.speech.tts.engine.GET_SAMPLE_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- TTS 引擎安装语音数据 -->
        <activity
            android:name=".tts.InstallVoiceData"
            android:exported="true">
            <intent-filter>
                <action android:name="android.speech.tts.engine.INSTALL_TTS_DATA" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- TTS 引擎服务 -->
        <!--
            不要给本服务声明 android:permission。
            android.permission.BIND_TEXT_TO_SPEECH_SERVICE 并不是 Android 系统中真实存在的权限
            （系统只有 BIND_INPUT_METHOD / BIND_ACCESSIBILITY_SERVICE / BIND_TEXT_SERVICE 等，
            并没有 TTS 的 BIND 权限）。一旦声明该权限，调用方（如阅读 Legado）就需要持有一个
            谁都拿不到的权限才能 bindService，在严格校验的 ROM（如 MIUI / Android 11）上会抛出
            SecurityException: Not allowed to bind to service ... act=android.intent.action.TTS_SERVICE。
            系统 TTS 引擎本就允许任意应用通过 TextToSpeech 框架绑定，故保持 exported 且不加权限即可。
        -->
        <service
            android:name=".tts.VoxEngineTTSService"
            android:enabled="true"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.TTS_SERVICE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="android.speech.tts"
                android:resource="@xml/tts_engine" />
        </service>

        <service
            android:name=".reader.ReaderPlaybackService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
