<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ 的备份与设备迁移规则。云备份与设备迁移都排除明文 API Key（DataStore）与日志。 -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore" />
        <exclude domain="file" path="logs" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore" />
        <exclude domain="file" path="logs" />
    </device-transfer>
</data-extraction-rules>
